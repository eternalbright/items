  "dependencies": {
    "@fastify/static": "^6.5.0",
    "@nestjs/common": "^9.0.11",
    "@nestjs/core": "^9.0.11",
    "@nestjs/platform-fastify": "^9.0.11",
    "@nestjs/swagger": "^6.1.1",
    "@prisma/client": "^4.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "prisma": "^4.3.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.1.1",
    "@tsconfig/node18-strictest": "^1.0.0",
    "@types/node": "^18.7.14",
    "prettier": "^2.7.1"
  }
