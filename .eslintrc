{
  "root": true,
  "env": {
    "es2021": true,
    "node": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "plugins": [
    "import",
    "prettier"
  ],
  "extends": [
    "airbnb-typescript/base",
    "prettier"
  ],
  "rules": {
    "prettier/prettier": "error"
  }
}
